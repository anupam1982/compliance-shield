
{
    "name": "compliance-shield",
    "version": "0.1.0",
    "description": "GitHub App for repository compliance and secret detection",
    "author": "Anupam Mukherjee",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/anupam1982/compliance-shield"
    },
    "main": "lib/app.js",
    "scripts": {
        "build": "tsc",
        "start": "npm run build && probot run ./lib/app.js",
        "scheduled-scan": "npm run build && node ./lib/scripts/runScheduledScan.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage"
    },
    "dependencies": {
        "dotenv": "^16.4.0",
        "js-yaml": "^4.1.1",
        "probot": "^13.0.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/jest": "^30.0.0",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^20.0.0",
        "jest": "^30.3.0",
        "ts-jest": "^29.4.6",
        "typescript": "^5.6.0"
    }
}
